# Database
DATABASE_URL=postgresql://user:password@localhost:5432/helearn?sslmode=require&uselibpqcompat=true

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT
JWT_SECRET=your-secret-key-here-min-32-chars
JWT_EXPIRY=7d

# Daraja (Safaricom M-PESA API)
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke
DARAJA_CONSUMER_KEY=your_consumer_key_from_daraja_dashboard
DARAJA_CONSUMER_SECRET=your_consumer_secret_from_daraja_dashboard
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your_passkey_from_daraja_dashboard
DARAJA_CALLBACK_URL=http://localhost:3001/api/mpesa/callback
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline

# PayPal API
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
